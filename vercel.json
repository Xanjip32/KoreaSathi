{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/about", "destination": "/pages/about.html" },
    { "source": "/contact", "destination": "/pages/contact.html" },
    { "source": "/guides", "destination": "/pages/guides.html" },
    { "source": "/guide", "destination": "/pages/guide.html" },
    { "source": "/videos", "destination": "/pages/videos.html" },
    { "source": "/organization", "destination": "/pages/organization.html" }
  ]
}
