{
  "name": "koreasathi",
  "version": "2.0.0",
  "description": "KoreaSathi - The Ultimate Student Hub for Korea",
  "scripts": {
    "dev": "concurrently \"npm run dev:css\" \"npm run dev:js\" \"npm run serve\"",
    "dev:css": "tailwindcss -i ./src/css/input.css -o ./dist/css/styles.css --watch",
    "dev:js": "esbuild src/js/main.js --bundle --outfile=dist/js/main.js --watch --format=esm --target=es2020",
    "build": "npm run build:css && npm run build:js && npm run copy:assets",
    "build:css": "tailwindcss -i ./src/css/input.css -o ./dist/css/styles.css --minify",
    "build:js": "esbuild src/js/main.js --bundle --outfile=dist/js/main.js --minify --format=esm --target=es2020",
    "copy:assets": "node -e \"require('fs').cpSync('src/assets','dist/assets',{recursive:true}); require('fs').cpSync('src/partials','dist/partials',{recursive:true}); require('fs').cpSync('src/pages','dist/pages',{recursive:true}); require('fs').cpSync('src/index.html','dist/index.html');\"",
    "serve": "npx serve dist -p 3000 -l 3000"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "esbuild": "^0.21.5",
    "flowbite": "^4.0.2",
    "postcss": "^8.4.38",
    "serve": "^14.2.3",
    "tailwindcss": "^3.4.4"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^6.5.2",
    "owl.carousel": "^2.3.4"
  }
}
